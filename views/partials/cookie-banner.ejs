<%# ===== COOKIE CONSENT BANNER + SETTINGS MODAL ===== %>
<%# CMP-lite: Banner (layer 1) + Settings modal (layer 2) + GTM Consent Mode %>

<!-- LAYER 1: Cookie Banner -->
<div id="cb-banner" class="cb-banner" style="display:none;" role="dialog" aria-label="<%= t.cookie.bannerTitle %>" aria-modal="false">
  <div class="cb-banner-inner">
    <div class="cb-banner-body">
      <p class="cb-banner-title"><%= t.cookie.bannerTitle %></p>
      <p class="cb-banner-text"><%= t.cookie.bannerText %></p>
      <a href="<%= langPrefix %>/cookie-policy" class="cb-banner-link"><%= t.cookie.learnMore %></a>
    </div>
    <div class="cb-banner-actions">
      <button id="cb-accept-all" class="cb-btn cb-btn--primary"><%= t.cookie.acceptAll %></button>
      <button id="cb-reject-all" class="cb-btn cb-btn--primary"><%= t.cookie.rejectAll %></button>
      <button id="cb-customize" class="cb-btn cb-btn--secondary"><%= t.cookie.customize %></button>
    </div>
  </div>
</div>

<!-- LAYER 2: Settings Modal -->
<div id="cb-overlay" class="cb-overlay" style="display:none;">
  <div id="cb-modal" class="cb-modal" role="dialog" aria-label="<%= t.cookie.settingsTitle %>" aria-modal="true">
    <div class="cb-modal-header">
      <p class="cb-modal-title"><%= t.cookie.settingsTitle %></p>
      <button id="cb-modal-close" class="cb-modal-close" aria-label="Close">&times;</button>
    </div>
    <div class="cb-modal-body">
      <!-- Necessary -->
      <div class="cb-category">
        <div class="cb-category-header">
          <div>
            <p class="cb-category-name"><%= t.cookie.necessaryTitle %></p>
            <p class="cb-category-desc"><%= t.cookie.necessaryDesc %></p>
          </div>
          <div class="cb-toggle cb-toggle--locked">
            <input type="checkbox" checked disabled id="cb-tog-necessary">
            <label for="cb-tog-necessary"></label>
          </div>
        </div>
      </div>
      <!-- Analytics -->
      <div class="cb-category">
        <div class="cb-category-header">
          <div>
            <p class="cb-category-name"><%= t.cookie.analyticsTitle %></p>
            <p class="cb-category-desc"><%= t.cookie.analyticsDesc %></p>
          </div>
          <div class="cb-toggle">
            <input type="checkbox" id="cb-tog-analytics">
            <label for="cb-tog-analytics"></label>
          </div>
        </div>
      </div>
      <!-- Marketing -->
      <div class="cb-category">
        <div class="cb-category-header">
          <div>
            <p class="cb-category-name"><%= t.cookie.marketingTitle %></p>
            <p class="cb-category-desc"><%= t.cookie.marketingDesc %></p>
          </div>
          <div class="cb-toggle">
            <input type="checkbox" id="cb-tog-marketing">
            <label for="cb-tog-marketing"></label>
          </div>
        </div>
      </div>
    </div>
    <div class="cb-modal-footer">
      <button id="cb-save" class="cb-btn cb-btn--primary"><%= t.cookie.saveChoices %></button>
      <button id="cb-modal-accept-all" class="cb-btn cb-btn--secondary"><%= t.cookie.acceptAll %></button>
      <button id="cb-modal-reject-all" class="cb-btn cb-btn--secondary"><%= t.cookie.rejectAll %></button>
    </div>
    <div class="cb-modal-link">
      <a href="<%= langPrefix %>/cookie-policy"><%= t.cookie.learnMore %></a>
    </div>
  </div>
</div>

<script>
(function() {
  var POLICY_VERSION = '1.0';
  var CONSENT_KEY = 'penger_consent';
  var CONSENT_TTL = 365 * 24 * 60 * 60 * 1000; // 12 months

  // --- DOM refs ---
  var banner = document.getElementById('cb-banner');
  var overlay = document.getElementById('cb-overlay');
  var togAnalytics = document.getElementById('cb-tog-analytics');
  var togMarketing = document.getElementById('cb-tog-marketing');

  // Consent default is set in head.ejs before GTM loads.
  // gtag() is already defined globally.

  // --- Read stored consent ---
  function readConsent() {
    try {
      var raw = localStorage.getItem(CONSENT_KEY);
      if (!raw) return null;
      var data = JSON.parse(raw);
      // Check expiry
      if (Date.now() - data.updated_at > CONSENT_TTL) {
        localStorage.removeItem(CONSENT_KEY);
        return null;
      }
      // Check policy version
      if (data.policy_version !== POLICY_VERSION) {
        localStorage.removeItem(CONSENT_KEY);
        return null;
      }
      return data;
    } catch (e) { return null; }
  }

  // --- Write consent ---
  function writeConsent(analytics, marketing) {
    var data = {
      necessary: true,
      analytics: analytics,
      marketing: marketing,
      updated_at: Date.now(),
      policy_version: POLICY_VERSION
    };
    localStorage.setItem(CONSENT_KEY, JSON.stringify(data));
    return data;
  }

  // --- Update GTM Consent Mode ---
  function updateGtmConsent(analytics, marketing) {
    gtag('consent', 'update', {
      analytics_storage: analytics ? 'granted' : 'denied',
      ad_storage: marketing ? 'granted' : 'denied',
      ad_user_data: marketing ? 'granted' : 'denied',
      ad_personalization: marketing ? 'granted' : 'denied'
    });
  }

  // --- Push consent event to dataLayer ---
  function pushConsentEvent(eventName, analytics, marketing) {
    window.dataLayer.push({
      event: eventName,
      consent_analytics: analytics,
      consent_marketing: marketing,
      consent_version: POLICY_VERSION
    });
  }

  // --- Delete analytics/marketing cookies ---
  function deleteCookies() {
    var patterns = ['_ga', '_gid', '_gat', '_clck', '_clsk', 'CLID', 'ANONCHK', 'MR', 'MUID', 'SM', '_fbp', 'fr'];
    document.cookie.split(';').forEach(function(c) {
      var name = c.split('=')[0].trim();
      for (var i = 0; i < patterns.length; i++) {
        if (name === patterns[i] || name.indexOf('_ga_') === 0 || name.indexOf('_gat_') === 0) {
          document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + location.hostname;
          document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
          break;
        }
      }
    });
  }

  // --- Apply consent ---
  function applyConsent(analytics, marketing, eventName) {
    writeConsent(analytics, marketing);
    updateGtmConsent(analytics, marketing);
    pushConsentEvent(eventName, analytics, marketing);
    if (!analytics && !marketing) deleteCookies();
    else if (!analytics) deleteCookies(); // clean analytics cookies
    else if (!marketing) {
      // clean only marketing cookies
      ['_fbp', 'fr'].forEach(function(name) {
        document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/;domain=.' + location.hostname;
        document.cookie = name + '=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/';
      });
    }
    hideBanner();
    hideModal();
  }

  // --- Show/hide ---
  function showBanner() { banner.style.display = ''; }
  function hideBanner() { banner.style.display = 'none'; }
  function showModal() {
    overlay.style.display = '';
    document.body.style.overflow = 'hidden';
  }
  function hideModal() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  // --- Init ---
  var stored = readConsent();
  if (stored) {
    // Apply stored consent silently
    updateGtmConsent(stored.analytics, stored.marketing);
  } else {
    // No consent yet — show banner
    showBanner();
  }

  // --- Banner buttons ---
  document.getElementById('cb-accept-all').addEventListener('click', function() {
    applyConsent(true, true, 'consent_accept_all');
  });
  document.getElementById('cb-reject-all').addEventListener('click', function() {
    applyConsent(false, false, 'consent_reject_all');
  });
  document.getElementById('cb-customize').addEventListener('click', function() {
    hideBanner();
    // Reset toggles to unchecked (default off)
    togAnalytics.checked = false;
    togMarketing.checked = false;
    showModal();
  });

  // --- Modal buttons ---
  document.getElementById('cb-save').addEventListener('click', function() {
    applyConsent(togAnalytics.checked, togMarketing.checked, 'consent_update');
  });
  document.getElementById('cb-modal-accept-all').addEventListener('click', function() {
    applyConsent(true, true, 'consent_accept_all');
  });
  document.getElementById('cb-modal-reject-all').addEventListener('click', function() {
    applyConsent(false, false, 'consent_reject_all');
  });
  document.getElementById('cb-modal-close').addEventListener('click', function() {
    hideModal();
    // If no stored consent, re-show banner
    if (!readConsent()) showBanner();
  });
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) {
      hideModal();
      if (!readConsent()) showBanner();
    }
  });

  // --- Footer "Cookie Settings" button ---
  window.openCookieSettings = function() {
    var existing = readConsent();
    togAnalytics.checked = existing ? existing.analytics : false;
    togMarketing.checked = existing ? existing.marketing : false;
    hideBanner();
    showModal();
  };
})();
</script>
