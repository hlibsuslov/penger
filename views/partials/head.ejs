<!-- Referral capture (single source of truth) — stores in sessionStorage + localStorage with 7-day TTL -->
<script>try{var _p=new URLSearchParams(location.search),_r=_p.get('ref');if(_r){_r=_r.trim().toUpperCase();if(_r.length>=2&&_r.length<=30&&/^[A-Z0-9_-]+$/.test(_r)){sessionStorage.setItem('penger_referral',_r);try{localStorage.setItem('penger_referral',JSON.stringify({code:_r,ts:Date.now()}))}catch(e){}}}}catch(e){}</script>
