<!DOCTYPE html><html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
  <% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(css) { %>
  <link rel="stylesheet" href="/<%= css %>">
  <% }); } %>
  <title><%= pageTitle %></title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "<%= pageTitle %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/dictionary",
    "description": "<%= pageDescription %>",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "All",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "<%= lang === 'uk' ? 'Головна' : 'Home' %>", "item": "<%= canonicalBase %><%= langPrefix %>/" },
      { "@type": "ListItem", "position": 2, "name": "<%= lang === 'uk' ? 'Словник' : 'Dictionary' %>" }
    ]
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    "name": "BIP39 Word List",
    "description": "<%= pageDescription %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/dictionary",
    "license": "https://opensource.org/licenses/MIT",
    "creator": {
      "@type": "Organization",
      "name": "PENGER"
    }
  }
  </script>
</head>
<body class="page-dictionary">
  <%- include('../partials/gtm-body') %>
  <noscript><p style="padding:40px;text-align:center;font-size:16px;">JavaScript is required.</p></noscript>
  <%- include('../partials/header') %>

  <main>
    <!-- SECTION INTRO -->
    <section class="section-intro" data-section="dictionary-intro">
      <div class="container">
        <p class="label"><%= t.dictionary.label %></p>
        <h1><%= t.dictionary.h1 %></h1>
        <p class="body-text">
          <%= t.dictionary.intro %>
        </p>
      </div>
    </section>

    <!-- PDF DOWNLOAD -->
    <section class="dict-pdf-section" data-section="dictionary-pdf">
      <div class="container">
        <button class="dict-pdf-btn" type="button" id="dictPdfBtn" data-track="cta_click" data-cta-id="dictionary_download_pdf">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M10 3v10m0 0l-3.5-3.5M10 13l3.5-3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M4 15.5h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <%= t.dictionary.downloadPdf %>
        </button>
        <p class="dict-pdf-hint"><%= t.dictionary.downloadDesc %></p>
      </div>
    </section>

    <!-- DICTIONARY SECTION -->
    <section class="section-block" data-section="dictionary-main">
      <div class="container">

        <!-- EXAMPLE ANIMATION -->
        <div class="dict-example-bar" style="margin-top: 20px;">
          <div class="dict-example-label"><%= t.dictionary.howToRead %></div>

          <!-- Step 1: mock compact dict-row -->
          <div class="ex-step">
            <div class="ex-anno-tag"><%= t.dictionary.exAnnoRow %></div>
            <div class="ex-mock-row">
              <span class="ex-mock-idx" translate="no">0628</span>
              <span class="ex-mock-word" translate="no" id="dictExampleWord">EXAMPLE</span>
              <span class="ex-mock-dots" id="dictExampleDots"></span>
              <span class="ex-mock-expand">+</span>
            </div>
            <!-- Annotation arrows for row parts -->
            <div class="ex-anno-row">
              <span class="ex-anno-item" data-for="idx"><span class="ex-anno-arrow"></span><%= t.dictionary.exAnnoIndex %></span>
              <span class="ex-anno-item" data-for="word"><span class="ex-anno-arrow"></span><%= t.dictionary.exAnnoWord %></span>
              <span class="ex-anno-item" data-for="dots"><span class="ex-anno-arrow"></span><%= t.dictionary.exAnnoBinary %></span>
            </div>
          </div>

          <!-- Connector arrow -->
          <div class="ex-connector">
            <svg width="24" height="32" viewBox="0 0 24 32" fill="none">
              <path d="M12 0 L12 24 M5 18 L12 26 L19 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="ex-connector-label"><%= t.dictionary.exAnnoDetail %></span>
          </div>

          <!-- Step 2: expanded detail view -->
          <div class="ex-step">
            <div class="ex-detail-block">
              <div class="ex-detail-header">
                <span class="ex-detail-word" translate="no">example</span>
                <span class="ex-detail-index">0628</span>
              </div>
              <div class="ex-detail-grid-section">
                <div class="dict-example-grid-wrap">
                  <div class="detail-binary-cells" id="dictExampleGrid"></div>
                </div>
                <div class="dict-example-formula" id="dictExampleFormula"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- SEARCH + COUNT -->
        <div class="dict-controls">
          <input
            type="text"
            class="dict-search"
            id="dictSearch"
            placeholder="<%= t.dictionary.searchPlaceholder %>"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="none"
            spellcheck="false"
            translate="no"
          >
          <span class="dict-count" id="dictCount"><%= t.dictionary.totalWords %></span>
        </div>

        <!-- ALPHABET FILTER -->
        <div class="dict-alpha" id="dictAlpha"></div>

        <!-- WORD LIST -->
        <div class="dict-list" id="dictList"></div>

      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="/analytics.js"></script>
  <script src="/shared.js?v=3"></script>
  <% if (typeof extraJs !== 'undefined') { extraJs.forEach(function(js) { %>
  <script src="/<%= js %>?v=4"></script>
  <% }); } %>
</body>
</html>
