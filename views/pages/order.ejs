<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
  <% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(css) { %>
  <link rel="stylesheet" href="/<%= css %>">
  <% }); } %>
  <title><%= pageTitle %></title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "PENGER v1.0",
    "description": "<%= pageDescription %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/order",
    "image": "<%= canonicalBase %>/imagepackage.png",
    "brand": { "@type": "Brand", "name": "PENGER" },
    "material": "Grade 2 Titanium (ASTM B265)",
    "offers": {
      "@type": "Offer",
      "price": "49.00",
      "priceCurrency": "USD",
      "priceValidUntil": "2026-12-31",
      "availability": "https://schema.org/PreOrder",
      "url": "<%= canonicalBase %><%= langPrefix %>/order"
    }
  }
  </script>
  <style>
    /* ===== ORDER PAGE LAYOUT ===== */
    .order-page { padding: 48px 0 80px; }

    .order-header { text-align: center; margin-bottom: 48px; }
    .order-header .label { margin-bottom: 12px; }
    .order-header h1 { font-family: var(--font-sans); font-size: 32px; font-weight: 700; color: var(--text-accent); letter-spacing: -0.02em; margin-bottom: 8px; }
    .order-header p { font-size: 14px; color: var(--text-label); }

    .order-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 40px;
      align-items: start;
    }

    /* ===== LEFT: PRODUCT CONFIG ===== */
    .order-product {}

    /* Product image gallery */
    .order-gallery {
      position: relative;
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 32px;
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .order-gallery img {
      max-width: 80%;
      max-height: 80%;
      object-fit: contain;
      transition: opacity 0.3s ease;
    }
    .order-gallery-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      padding: 4px 10px;
      border-radius: 4px;
    }

    /* Finish selector */
    .order-section { margin-bottom: 28px; }
    .order-section-title {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      margin-bottom: 12px;
    }

    .finish-options { display: flex; gap: 12px; }
    .finish-option {
      flex: 1;
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      background: var(--bg-surface);
      border: 2px solid var(--border-default);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    .finish-option:hover { border-color: var(--border-hover); }
    .finish-option.active { border-color: var(--text-accent); }
    .finish-option input { display: none; }
    .finish-swatch {
      width: 36px; height: 36px;
      border-radius: 6px;
      border: 1px solid var(--border-default);
      flex-shrink: 0;
    }
    .finish-swatch.swatch-ocean { background: linear-gradient(135deg, #1a3a5c, #2d6b9e); }
    .finish-swatch.swatch-mat { background: linear-gradient(135deg, #8a8a8a, #b0b0b0); }
    .finish-info { flex: 1; min-width: 0; }
    .finish-name {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--text-accent);
      margin-bottom: 2px;
    }
    .finish-desc {
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--text-dim);
      line-height: 1.4;
    }
    .finish-check {
      width: 20px; height: 20px;
      border: 2px solid var(--border-default);
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s ease, background 0.2s ease;
    }
    .finish-option.active .finish-check {
      border-color: var(--text-accent);
      background: var(--text-accent);
    }
    .finish-check svg { display: none; }
    .finish-option.active .finish-check svg { display: block; }

    /* Quantity selector */
    .qty-selector {
      display: inline-flex;
      align-items: center;
      gap: 0;
      border: 1px solid var(--border-default);
      border-radius: 6px;
      overflow: hidden;
    }
    .qty-btn {
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg-surface);
      border: none;
      cursor: pointer;
      font-size: 18px;
      color: var(--text-accent);
      transition: background 0.15s ease;
      font-family: var(--font-mono);
    }
    .qty-btn:hover { background: var(--bg-surface-hover); }
    .qty-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .qty-val {
      width: 56px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono);
      font-size: 16px;
      font-weight: 600;
      color: var(--text-accent);
      border-left: 1px solid var(--border-default);
      border-right: 1px solid var(--border-default);
      background: var(--bg-main);
    }

    /* Kit contents */
    .kit-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .kit-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      font-size: 13px;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-default);
    }
    .kit-list li:last-child { border-bottom: none; }
    .kit-check {
      width: 16px; height: 16px;
      color: var(--text-accent);
      flex-shrink: 0;
    }

    /* Specs table */
    .specs-table {
      width: 100%;
      border-collapse: collapse;
    }
    .specs-table tr { border-bottom: 1px solid var(--border-default); }
    .specs-table tr:last-child { border-bottom: none; }
    .specs-table td {
      padding: 8px 0;
      font-size: 12px;
      font-family: var(--font-mono);
    }
    .specs-table td:first-child {
      color: var(--text-dim);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      width: 40%;
    }
    .specs-table td:last-child { color: var(--text-primary); }

    /* ===== RIGHT: ORDER SUMMARY SIDEBAR ===== */
    .order-sidebar {
      position: sticky;
      top: calc(var(--header-h) + 24px);
    }
    .order-summary {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      padding: 24px;
    }
    .order-summary-title {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-default);
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      font-family: var(--font-mono);
      font-size: 12px;
    }
    .summary-key {
      color: var(--text-dim);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .summary-val { color: var(--text-accent); font-weight: 600; }
    .summary-divider {
      height: 1px;
      background: var(--border-default);
      margin: 12px 0;
    }
    .summary-total .summary-key,
    .summary-total .summary-val {
      font-size: 16px;
      color: var(--text-accent);
      font-weight: 700;
    }
    .summary-finish-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }
    .summary-finish-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      border: 1px solid var(--border-default);
    }
    .summary-finish-dot.dot-ocean { background: #2d6b9e; }
    .summary-finish-dot.dot-mat { background: #a0a0a0; }

    /* Checkout button */
    .order-checkout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 16px 24px;
      margin-top: 20px;
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--bg-main);
      background: var(--text-accent);
      border: 1px solid var(--text-accent);
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s ease, box-shadow 0.2s ease;
      min-height: 52px;
      text-decoration: none;
    }
    .order-checkout-btn:hover {
      background: var(--text-accent-hover);
      box-shadow: 0 0 20px var(--glow);
    }
    .order-checkout-btn svg { flex-shrink: 0; }

    .order-notes {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .order-note {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-dim);
    }
    .order-note svg {
      width: 14px; height: 14px;
      flex-shrink: 0;
      color: var(--text-dim);
    }

    /* Back link */
    .order-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-dim);
      text-decoration: none;
      margin-bottom: 24px;
      transition: color 0.2s ease;
    }
    .order-back:hover { color: var(--text-accent); }
    .order-back svg { width: 14px; height: 14px; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 860px) {
      .order-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .order-sidebar {
        position: static;
      }
      .order-header h1 { font-size: 26px; }
    }
    @media (max-width: 520px) {
      .order-page { padding: 32px 0 60px; }
      .order-header h1 { font-size: 22px; }
      .finish-options { flex-direction: column; }
      .order-gallery { aspect-ratio: 3/2; }
    }
  </style>
</head>
<body>
  <%- include('../partials/gtm-body') %>
  <noscript><p style="padding:40px;text-align:center;font-size:16px;">JavaScript is required.</p></noscript>
  <%- include('../partials/header') %>

  <main class="order-page" role="main">
    <div class="container">

      <a href="<%= langPrefix %>/" class="order-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        <%= t.order.backToProduct %>
      </a>

      <div class="order-header">
        <p class="label"><%= t.order.label %></p>
        <h1><%= t.order.h1 %></h1>
        <p><%= t.order.desc %></p>
      </div>

      <div class="order-grid">

        <!-- ===== LEFT: PRODUCT ===== -->
        <div class="order-product">

          <!-- Gallery -->
          <div class="order-gallery" id="orderGallery">
            <span class="order-gallery-badge">PENGER v1.0</span>
            <picture>
              <source id="galleryDark" srcset="/photo/oceanW.png" media="(prefers-color-scheme: dark)">
              <img id="galleryImg" src="/photo/oceanB.png" alt="Penger v1.0 — Ocean finish" loading="eager">
            </picture>
          </div>

          <!-- Finish selector -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.finishLabel %></p>
            <div class="finish-options" id="finishOptions">
              <label class="finish-option active" data-finish="ocean">
                <input type="radio" name="finish" value="ocean" checked>
                <span class="finish-swatch swatch-ocean"></span>
                <span class="finish-info">
                  <span class="finish-name"><%= t.order.finishOcean %></span>
                  <span class="finish-desc"><%= t.order.finishOceanDesc %></span>
                </span>
                <span class="finish-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
              </label>
              <label class="finish-option" data-finish="mat">
                <input type="radio" name="finish" value="mat">
                <span class="finish-swatch swatch-mat"></span>
                <span class="finish-info">
                  <span class="finish-name"><%= t.order.finishMat %></span>
                  <span class="finish-desc"><%= t.order.finishMatDesc %></span>
                </span>
                <span class="finish-check">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                </span>
              </label>
            </div>
          </div>

          <!-- Quantity -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.qtyLabel %></p>
            <div class="qty-selector">
              <button class="qty-btn" id="qtyMinus" type="button" disabled aria-label="Decrease quantity">&minus;</button>
              <span class="qty-val" id="qtyVal">1</span>
              <button class="qty-btn" id="qtyPlus" type="button" aria-label="Increase quantity">&plus;</button>
            </div>
          </div>

          <!-- Kit contents -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.kitContentsLabel %></p>
            <ul class="kit-list">
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem1 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem2 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem3 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem4 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem5 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem6 %></li>
            </ul>
          </div>

          <!-- Specs -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.specsLabel %></p>
            <table class="specs-table">
              <tr><td><%= t.order.specMaterial %></td><td><%= t.order.specMaterialVal %></td></tr>
              <tr><td><%= t.order.specDimensions %></td><td><%= t.order.specDimensionsVal %></td></tr>
              <tr><td><%= t.order.specCapacity %></td><td><%= t.order.specCapacityVal %></td></tr>
              <tr><td><%= t.order.specWeight %></td><td><%= t.order.specWeightVal %></td></tr>
              <tr><td><%= t.order.specFire %></td><td><%= t.order.specFireVal %></td></tr>
            </table>
          </div>
        </div>

        <!-- ===== RIGHT: ORDER SUMMARY ===== -->
        <div class="order-sidebar">
          <div class="order-summary">
            <p class="order-summary-title"><%= t.order.summaryLabel %></p>

            <div class="summary-row">
              <span class="summary-key">PENGER v1.0</span>
              <span class="summary-val summary-finish-badge">
                <span class="summary-finish-dot dot-ocean" id="summaryFinishDot"></span>
                <span id="summaryFinishName"><%= t.order.finishOcean %></span>
              </span>
            </div>
            <div class="summary-row">
              <span class="summary-key"><%= t.order.priceLabel %></span>
              <span class="summary-val" id="summaryPrice">$49</span>
            </div>
            <div class="summary-row">
              <span class="summary-key"><%= t.order.qtyLabel %></span>
              <span class="summary-val" id="summaryQty">1</span>
            </div>
            <div class="summary-row">
              <span class="summary-key"><%= t.order.shippingLabel %></span>
              <span class="summary-val"><%= t.order.shippingValue %></span>
            </div>

            <div class="summary-divider"></div>

            <div class="summary-row summary-total">
              <span class="summary-key"><%= t.order.totalLabel %></span>
              <span class="summary-val" id="summaryTotal">$49</span>
            </div>

            <button class="order-checkout-btn" id="checkoutBtn" type="button"
              data-track="checkout_start" data-cta-id="order_checkout" data-section="order" data-product-id="penger-v1">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              <%= t.order.checkoutBtn %>
            </button>

            <div class="order-notes">
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <%= t.order.preorderNote %>
              </span>
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <%= t.order.warrantyNote %>
              </span>
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <%= t.order.secureNote %>
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/analytics.js"></script>
  <script src="/shared.js?v=2"></script>
  <script>
  (function () {
    'use strict';

    var UNIT_PRICE = 49;
    var qty = 1;
    var finish = 'ocean';

    /* DOM refs */
    var qtyVal = document.getElementById('qtyVal');
    var qtyMinus = document.getElementById('qtyMinus');
    var qtyPlus = document.getElementById('qtyPlus');
    var finishOptions = document.getElementById('finishOptions');
    var galleryImg = document.getElementById('galleryImg');
    var galleryDark = document.getElementById('galleryDark');
    var summaryFinishDot = document.getElementById('summaryFinishDot');
    var summaryFinishName = document.getElementById('summaryFinishName');
    var summaryPrice = document.getElementById('summaryPrice');
    var summaryQty = document.getElementById('summaryQty');
    var summaryTotal = document.getElementById('summaryTotal');
    var checkoutBtn = document.getElementById('checkoutBtn');

    var finishNames = {
      ocean: '<%= t.order.finishOcean %>',
      mat: '<%= t.order.finishMat %>'
    };

    var finishImages = {
      ocean: { light: '/photo/oceanB.png', dark: '/photo/oceanW.png' },
      mat:   { light: '/photo/matB.png',   dark: '/photo/matW.png' }
    };

    function updateUI() {
      qtyVal.textContent = qty;
      qtyMinus.disabled = qty <= 1;
      qtyPlus.disabled = qty >= 10;
      summaryQty.textContent = qty;

      var total = qty * UNIT_PRICE;
      summaryPrice.textContent = '$' + UNIT_PRICE;
      summaryTotal.textContent = '$' + total;

      /* Finish */
      summaryFinishName.textContent = finishNames[finish];
      summaryFinishDot.className = 'summary-finish-dot dot-' + finish;

      var imgs = finishImages[finish];
      galleryImg.src = imgs.light;
      galleryImg.alt = 'Penger v1.0 — ' + finishNames[finish] + ' finish';
      if (galleryDark) galleryDark.srcset = imgs.dark;
    }

    /* Qty buttons */
    qtyMinus.addEventListener('click', function () { if (qty > 1) { qty--; updateUI(); } });
    qtyPlus.addEventListener('click', function () { if (qty < 10) { qty++; updateUI(); } });

    /* Finish selector */
    finishOptions.addEventListener('click', function (e) {
      var option = e.target.closest('.finish-option');
      if (!option) return;
      var input = option.querySelector('input');
      if (!input) return;

      finishOptions.querySelectorAll('.finish-option').forEach(function (o) { o.classList.remove('active'); });
      option.classList.add('active');
      input.checked = true;
      finish = input.value;
      updateUI();
    });

    /* Checkout — placeholder until Stripe integration */
    checkoutBtn.addEventListener('click', function () {
      /* TODO: Replace with real Stripe Checkout session creation */
      var params = new URLSearchParams({
        product: 'penger-v1',
        finish: finish,
        qty: qty
      });
      alert('<%= lang === "uk" ? "Оплата через Stripe буде доступна найближчим часом. Дякуємо за інтерес!" : "Stripe checkout coming soon. Thank you for your interest!" %>');
    });

    updateUI();
  })();
  </script>
</body>
</html>
