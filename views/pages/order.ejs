<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
  <% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(css) { %>
  <link rel="stylesheet" href="/<%= css %>">
  <% }); } %>
  <title><%= pageTitle %></title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "PENGER v1.0",
    "description": "<%= pageDescription %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/order",
    "image": "<%= canonicalBase %>/imagepackage.png",
    "brand": { "@type": "Brand", "name": "PENGER" },
    "material": "Grade 2 Titanium (ASTM B265)",
    "offers": {
      "@type": "Offer",
      "price": "49.00",
      "priceCurrency": "EUR",
      "priceValidUntil": "2026-12-31",
      "availability": "https://schema.org/PreOrder",
      "url": "<%= canonicalBase %><%= langPrefix %>/order"
    }
  }
  </script>
  <style>
    /* ===== ORDER PAGE LAYOUT ===== */
    .order-page { padding: 48px 0 80px; }

    .order-header { text-align: center; margin-bottom: 48px; }
    .order-header .label { margin-bottom: 12px; }
    .order-header h1 { font-family: var(--font-sans); font-size: 32px; font-weight: 700; color: var(--text-accent); letter-spacing: -0.02em; margin-bottom: 8px; }
    .order-header p { font-size: 14px; color: var(--text-label); }

    .order-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 80px;
      align-items: start;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ===== LEFT: PRODUCT CONFIG ===== */
    .order-product {}

    /* Product image gallery */
    .order-gallery {
      position: relative;
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 32px;
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .order-gallery img {
      max-width: 80%;
      max-height: 80%;
      object-fit: contain;
      transition: opacity 0.3s ease;
    }
    .order-gallery-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      padding: 4px 10px;
      border-radius: 4px;
    }
    .order-gallery-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 12px;
      color: var(--text-dim);
    }
    .order-gallery-placeholder svg { width: 48px; height: 48px; opacity: 0.4; }
    .order-gallery-placeholder span {
      font-family: var(--font-mono);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      opacity: 0.5;
    }

    /* Config section */
    .order-section { margin-bottom: 28px; }
    .order-section-title {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      margin-bottom: 12px;
    }
    .order-section-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 12px;
    }
    .order-section-price {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-label);
      font-weight: 600;
    }

    /* Config option cards */
    .config-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      padding: 14px 16px;
      margin-bottom: 10px;
    }
    .config-card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .config-card-title {
      font-family: var(--font-sans);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-accent);
    }
    .config-card-price {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      color: var(--text-label);
      white-space: nowrap;
    }
    .config-options {
      display: flex;
      gap: 8px;
    }
    .config-opt {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 9px 12px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      color: var(--text-dim);
      background: var(--bg-main);
      border: 1.5px solid var(--border-default);
      border-radius: 6px;
      cursor: pointer;
      transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      user-select: none;
    }
    .config-opt:hover {
      border-color: var(--border-hover);
      color: var(--text-primary);
    }
    .config-opt.active {
      border-color: var(--text-accent);
      color: var(--text-accent);
      background: var(--bg-surface);
    }
    .config-opt input { display: none; }
    .config-swatch {
      width: 14px; height: 14px;
      border-radius: 50%;
      border: 1.5px solid var(--border-default);
      flex-shrink: 0;
    }
    .config-swatch-black { background: #1a1a1a; border-color: #333; }
    .config-swatch-white { background: #f5f5f5; border-color: #ccc; }
    .config-opt.active .config-swatch { border-color: var(--text-accent); }

    /* Kit description */
    .kit-description {
      font-family: var(--font-sans);
      font-size: 14px;
      line-height: 1.7;
      color: var(--text-primary);
      margin-bottom: 20px;
    }
    .kit-description p {
      margin: 0 0 12px;
    }
    .kit-description p:last-child { margin-bottom: 0; }

    /* Quantity selector (reused for plates) */
    .qty-selector {
      display: inline-flex;
      align-items: center;
      gap: 0;
      border: 1px solid var(--border-default);
      border-radius: 6px;
      overflow: hidden;
    }
    .qty-btn {
      width: 44px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      background: var(--bg-surface);
      border: none;
      cursor: pointer;
      font-size: 18px;
      color: var(--text-accent);
      transition: background 0.15s ease;
      font-family: var(--font-mono);
    }
    .qty-btn:hover { background: var(--bg-surface-hover); }
    .qty-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .qty-val {
      width: 56px; height: 44px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-mono);
      font-size: 16px;
      font-weight: 600;
      color: var(--text-accent);
      border-left: 1px solid var(--border-default);
      border-right: 1px solid var(--border-default);
      background: var(--bg-main);
    }


    /* Kit contents */
    .kit-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .kit-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      font-size: 13px;
      color: var(--text-primary);
      border-bottom: 1px solid var(--border-default);
    }
    .kit-list li:last-child { border-bottom: none; }
    .kit-check {
      width: 16px; height: 16px;
      color: var(--text-accent);
      flex-shrink: 0;
    }

    /* Specs table */
    .specs-table {
      width: 100%;
      border-collapse: collapse;
    }
    .specs-table tr { border-bottom: 1px solid var(--border-default); }
    .specs-table tr:last-child { border-bottom: none; }
    .specs-table td {
      padding: 8px 0;
      font-size: 12px;
      font-family: var(--font-mono);
    }
    .specs-table td:first-child {
      color: var(--text-dim);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      width: 40%;
    }
    .specs-table td:last-child { color: var(--text-primary); }

    /* ===== RIGHT: ORDER SUMMARY SIDEBAR ===== */
    .order-sidebar {
      position: sticky;
      top: calc(var(--header-h) + 24px);
    }
    .order-summary {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      padding: 24px;
    }
    .order-summary-title {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border-default);
    }

    /* Cart item */
    .cart-item {
      display: flex;
      gap: 14px;
      padding-bottom: 16px;
      margin-bottom: 16px;
      border-bottom: 1px solid var(--border-default);
    }
    .cart-thumb {
      width: 72px; height: 72px;
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }
    .cart-thumb svg {
      width: 28px; height: 28px;
      color: var(--text-dim);
      opacity: 0.4;
    }
    .cart-thumb img {
      width: 100%; height: 100%;
      object-fit: cover;
    }
    .cart-details { flex: 1; min-width: 0; }
    .cart-product-name {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 700;
      color: var(--text-accent);
      margin-bottom: 4px;
    }
    .cart-config-line {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--text-dim);
      line-height: 1.6;
    }
    .cart-config-line span { color: var(--text-primary); font-weight: 600; }

    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 3px 0;
      font-family: var(--font-mono);
      font-size: 12px;
    }
    .summary-key {
      color: var(--text-dim);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .summary-val { color: var(--text-accent); font-weight: 600; }
    .summary-val-free { color: var(--text-dim); font-weight: 600; }
    .summary-val-add { color: var(--text-label); font-weight: 600; }
    .summary-divider {
      height: 1px;
      background: var(--border-default);
      margin: 12px 0;
    }
    .summary-total .summary-key,
    .summary-total .summary-val {
      font-size: 16px;
      color: var(--text-accent);
      font-weight: 700;
    }

    /* Checkout button */
    .order-checkout-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 14px 20px;
      margin-top: 20px;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--bg-main);
      background: var(--text-accent);
      border: 1px solid var(--text-accent);
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s ease, box-shadow 0.2s ease;
      min-height: 46px;
      text-decoration: none;
    }
    .order-checkout-btn:hover {
      background: var(--text-accent-hover);
      box-shadow: 0 0 20px var(--glow);
    }
    .order-checkout-btn svg { flex-shrink: 0; }

    .order-notes {
      margin-top: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .order-note {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 400;
      color: var(--text-dim);
      line-height: 1.4;
    }
    .order-note svg {
      width: 14px; height: 14px;
      flex-shrink: 0;
      color: var(--text-dim);
    }

    /* Back link */
    .order-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-dim);
      text-decoration: none;
      margin-bottom: 24px;
      transition: color 0.2s ease;
    }
    .order-back:hover { color: var(--text-accent); }
    .order-back svg { width: 14px; height: 14px; }

    /* ===== CHECKOUT STEPS ===== */
    .checkout-step {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 10px;
      margin-bottom: 16px;
      overflow: hidden;
      transition: opacity 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    }
    .checkout-step.active {
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .checkout-step.disabled { opacity: 0.4; pointer-events: none; }
    .step-body {
      padding: 0 20px 20px;
      transition: max-height 0.35s ease, opacity 0.25s ease;
      overflow: hidden;
    }
    .checkout-step.active .step-body { opacity: 1; }
    .checkout-step:not(.active) .step-body { opacity: 0; max-height: 0 !important; padding: 0 20px 0; }
    .checkout-step.step-entering { animation: stepSlideIn 0.3s ease forwards; }
    @keyframes stepSlideIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .step-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 20px;
      cursor: default;
    }
    .step-header-left {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .step-number {
      width: 26px; height: 26px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      background: var(--bg-main);
      border: 2px solid var(--border-default);
      color: var(--text-dim);
      flex-shrink: 0;
      transition: all 0.2s ease;
    }
    .checkout-step.active .step-number,
    .checkout-step.completed .step-number {
      border-color: var(--text-accent);
      color: var(--text-accent);
    }
    .checkout-step.completed .step-number {
      background: var(--text-accent);
      color: var(--bg-main);
    }
    .step-title {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
      transition: color 0.2s ease;
    }
    .checkout-step.active .step-title,
    .checkout-step.completed .step-title {
      color: var(--text-accent);
    }
    .step-edit-btn {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-accent);
      background: none;
      border: 1px solid var(--border-default);
      border-radius: 4px;
      padding: 4px 10px;
      cursor: pointer;
      display: none;
      transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    .step-edit-btn:hover {
      border-color: var(--text-accent);
      background: var(--text-accent);
      color: var(--bg-main);
    }
    .checkout-step.completed .step-edit-btn { display: inline-flex; }
    .step-summary {
      display: none;
      padding: 0 20px 14px;
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--text-primary);
      line-height: 1.4;
    }
    .checkout-step.completed .step-summary { display: block; }
    .step-summary-line {
      display: flex;
      gap: 6px;
      align-items: baseline;
    }
    .step-summary-label {
      color: var(--text-dim);
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      min-width: 50px;
    }
    /* Form fields */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 8px;
    }
    .form-row.full { grid-template-columns: 1fr; }
    .form-group { display: flex; flex-direction: column; gap: 3px; }
    .form-label {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text-dim);
    }
    .form-input {
      font-family: var(--font-sans);
      font-size: 16px;
      color: var(--text-primary);
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      padding: 10px 12px;
      outline: none;
      transition: border-color 0.15s ease;
    }
    /* Important fields get slightly larger */
    .form-input-lg { padding: 12px 14px; }
    .form-input-sm { padding: 8px 12px; font-size: 14px; }
    .form-input:focus { border-color: var(--text-accent); }
    .form-input.error { border-color: #e74c3c; }
    .form-input::placeholder { color: var(--text-dim); opacity: 0.5; }
    .form-group { position: relative; }
    .zip-suggestions {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      z-index: 10;
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-top: none;
      border-radius: 0 0 6px 6px;
      max-height: 160px;
      overflow-y: auto;
      display: none;
    }
    .zip-suggestions.open { display: block; }
    .zip-suggestion {
      padding: 8px 12px;
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--text-primary);
      cursor: pointer;
      transition: background 0.1s ease;
    }
    .zip-suggestion:hover { background: var(--bg-surface); }
    .zip-suggestion .zip-code {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-dim);
      margin-left: 6px;
    }
    select.form-input {
      appearance: none;
      background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23666' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
      background-repeat: no-repeat;
      background-position: right 12px center;
      padding-right: 32px;
      padding-top: 11px;
      padding-bottom: 11px;
    }
    .form-privacy {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 12px;
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      margin-bottom: 12px;
    }
    .form-privacy svg {
      width: 13px; height: 13px;
      color: var(--text-dim);
      flex-shrink: 0;
    }
    .form-privacy span {
      font-family: var(--font-sans);
      font-size: 11px;
      color: var(--text-dim);
      line-height: 1.4;
    }
    .step-continue-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      width: 100%;
      padding: 13px 20px;
      margin-top: 14px;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--bg-main);
      background: var(--text-accent);
      border: 1px solid var(--text-accent);
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.2s ease, box-shadow 0.2s ease;
      min-height: 44px;
    }
    .step-continue-btn:hover { background: var(--text-accent-hover); }

    /* Payment methods */
    .pay-methods { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
    .pay-method {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      background: var(--bg-main);
      border: 2px solid var(--border-default);
      border-radius: 8px;
      cursor: pointer;
      transition: border-color 0.15s ease;
    }
    .pay-method:hover { border-color: var(--border-hover); }
    .pay-method.active { border-color: var(--text-accent); }
    .pay-method input { display: none; }
    .pay-radio {
      width: 18px; height: 18px;
      border: 2px solid var(--border-default);
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s ease;
    }
    .pay-method.active .pay-radio { border-color: var(--text-accent); }
    .pay-radio-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--text-accent);
      display: none;
    }
    .pay-method.active .pay-radio-dot { display: block; }
    .pay-method-info { flex: 1; }
    .pay-method-name {
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 600;
      color: var(--text-accent);
    }
    .pay-method-desc {
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--text-dim);
    }
    .pay-method-icons {
      display: flex;
      gap: 4px;
      align-items: center;
    }
    .pay-method-icons span {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      padding: 3px 6px;
      border: 1px solid var(--border-default);
      border-radius: 3px;
      color: var(--text-dim);
      background: var(--bg-surface);
    }
    .card-fields { margin-top: 12px; }
    .card-fields.hidden { display: none; }

    /* Checkboxes */
    .form-checkbox {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
      cursor: pointer;
    }
    .form-checkbox input { display: none; }
    .checkbox-box {
      width: 18px; height: 18px;
      border: 2px solid var(--border-default);
      border-radius: 4px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s ease, background 0.15s ease;
      margin-top: 1px;
    }
    .form-checkbox input:checked ~ .checkbox-box {
      border-color: var(--text-accent);
      background: var(--text-accent);
    }
    .checkbox-box svg { display: none; }
    .form-checkbox input:checked ~ .checkbox-box svg { display: block; }
    .checkbox-label {
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--text-primary);
      line-height: 1.4;
    }
    .checkbox-label a {
      color: var(--text-accent);
      text-decoration: underline;
    }

    /* Bottom order card */
    .order-bottom-card {
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 8px;
      padding: 20px;
      margin-top: 20px;
    }

    /* Progress bar */
    .order-progress {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      margin-bottom: 28px;
    }
    .progress-step {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-dim);
      transition: color 0.25s ease;
    }
    .progress-step.active,
    .progress-step.done { color: var(--text-accent); }
    .progress-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--border-default);
      transition: background 0.25s ease, transform 0.25s ease;
    }
    .progress-step.active .progress-dot {
      background: var(--text-accent);
      transform: scale(1.3);
    }
    .progress-step.done .progress-dot { background: var(--text-accent); }
    .progress-line {
      width: 32px; height: 2px;
      background: var(--border-default);
      margin: 0 8px;
      transition: background 0.25s ease;
      border-radius: 1px;
    }
    .progress-line.done { background: var(--text-accent); }

    /* Validation states */
    .form-input.valid { border-color: #2ecc71; }
    .form-input-wrap { position: relative; }
    .form-input-wrap .form-input { width: 100%; padding-right: 32px; }
    .input-check {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      width: 16px; height: 16px;
      color: #2ecc71;
      display: none;
    }
    .form-input.valid ~ .input-check { display: block; }

    /* Phone prefix */
    .phone-wrap { display: flex; gap: 8px; }
    .phone-prefix {
      min-width: 80px;
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--text-primary);
      background: var(--bg-surface);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      padding: 10px 10px;
      text-align: center;
      white-space: nowrap;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }
    .phone-wrap .form-input { flex: 1; }

    /* Card type highlight */
    .pay-method-icons span.detected {
      border-color: var(--text-accent);
      color: var(--text-accent);
      background: var(--bg-main);
    }

    /* Email suggestion */
    .email-suggestion {
      font-family: var(--font-sans);
      font-size: 12px;
      color: var(--text-dim);
      margin-top: 4px;
      cursor: pointer;
    }
    .email-suggestion span {
      color: var(--text-accent);
      text-decoration: underline;
      cursor: pointer;
    }

    /* Error micro-copy */
    .field-error-msg {
      font-family: var(--font-sans);
      font-size: 12px;
      color: #e74c3c;
      margin-top: 3px;
      display: none;
    }
    .form-input.error ~ .field-error-msg,
    .form-group.has-error .field-error-msg { display: block; }

    /* Estimated delivery */
    .delivery-estimate {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 12px;
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      margin-top: 12px;
      font-family: var(--font-sans);
      font-size: 13px;
      color: var(--text-primary);
    }
    .delivery-estimate svg {
      width: 16px; height: 16px;
      color: var(--text-accent);
      flex-shrink: 0;
    }
    .delivery-estimate strong { color: var(--text-accent); }

    /* Trust badges */
    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 16px;
      flex-wrap: wrap;
    }
    .trust-badge {
      display: flex;
      align-items: center;
      gap: 5px;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 400;
      color: var(--text-dim);
    }
    .trust-badge svg {
      width: 13px; height: 13px;
      color: var(--text-dim);
      flex-shrink: 0;
      opacity: 0.5;
    }

    /* Promo code */
    .promo-section { margin-top: 12px; }
    .promo-form {
      display: flex;
      gap: 8px;
    }
    .promo-input {
      flex: 1;
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text-primary);
      background: var(--bg-main);
      border: 1px solid var(--border-default);
      border-radius: 6px;
      padding: 8px 12px;
      outline: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .promo-input:focus { border-color: var(--text-accent); }
    .promo-apply {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--bg-main);
      background: var(--text-accent);
      border: none;
      border-radius: 6px;
      padding: 8px 16px;
      cursor: pointer;
      white-space: nowrap;
    }
    .promo-msg {
      font-family: var(--font-sans);
      font-size: 12px;
      margin-top: 4px;
      display: none;
    }
    .promo-msg.success { color: #2ecc71; display: block; }
    .promo-msg.error { color: #e74c3c; display: block; }

    /* Shipping cost dynamic */
    .shipping-val-dynamic { color: var(--text-label); font-weight: 600; }

    @media (prefers-color-scheme: dark) {
      .checkout-step.active { box-shadow: 0 2px 16px rgba(0,0,0,0.25); }
      .mobile-sticky-cta { box-shadow: 0 -2px 16px rgba(0,0,0,0.3); }
    }

    /* Disabled checkout button */
    .order-checkout-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
    .order-checkout-btn:disabled:hover {
      background: var(--text-accent);
      box-shadow: none;
    }

    /* Sticky mobile CTA */
    .mobile-sticky-cta {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--bg-surface);
      border-top: 1px solid var(--border-default);
      padding: 16px 20px calc(16px + env(safe-area-inset-bottom, 0px));
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }
    .mobile-sticky-price {
      font-family: var(--font-mono);
      font-size: 20px;
      font-weight: 700;
      color: var(--text-accent);
    }
    .mobile-sticky-btn {
      flex: 1;
      max-width: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 14px 20px;
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--bg-main);
      background: var(--text-accent);
      border: none;
      border-radius: 8px;
      cursor: pointer;
      min-height: 48px;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 860px) {
      .order-grid {
        grid-template-columns: 1fr;
        gap: 32px;
      }
      .order-sidebar {
        position: static;
      }
      .order-header h1 { font-size: 26px; }
      .mobile-sticky-cta { display: flex; }
      .order-page { padding-bottom: 120px; }
    }
    @media (max-width: 520px) {
      .order-page { padding: 32px 0 120px; }
      .order-header h1 { font-size: 22px; }
      .order-gallery { aspect-ratio: 3/2; }
      .form-row { grid-template-columns: 1fr; }
      .progress-step span { display: none; }
      .progress-line { width: 24px; }
      .form-input { font-size: 16px; }
    }
  </style>
</head>
<body>
  <%- include('../partials/gtm-body') %>
  <noscript><p style="padding:40px;text-align:center;font-size:16px;">JavaScript is required.</p></noscript>
  <%- include('../partials/header') %>

  <main class="order-page" role="main" data-section="order">
    <div class="container">

      <a href="<%= langPrefix %>/" class="order-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        <%= t.order.backToProduct %>
      </a>

      <!-- Progress bar -->
      <div class="order-progress" id="orderProgress">
        <div class="progress-step done" data-step="product">
          <span class="progress-dot"></span>
          <span><%= t.order.progressProduct %></span>
        </div>
        <div class="progress-line done" id="progressLine1"></div>
        <div class="progress-step active" data-step="contact">
          <span class="progress-dot"></span>
          <span><%= t.order.progressContact %></span>
        </div>
        <div class="progress-line" id="progressLine2"></div>
        <div class="progress-step" data-step="delivery">
          <span class="progress-dot"></span>
          <span><%= t.order.deliveryAddress || 'Delivery' %></span>
        </div>
        <div class="progress-line" id="progressLine3"></div>
        <div class="progress-step" data-step="payment">
          <span class="progress-dot"></span>
          <span><%= t.order.progressPayment %></span>
        </div>
      </div>

      <div class="order-grid">

        <!-- ===== LEFT: PRODUCT CONFIG ===== -->
        <div class="order-product">

          <!-- Gallery placeholder -->
          <div class="order-gallery" id="orderGallery"
            data-track="product_image_view" data-cta-id="order_product_image" data-section="order" data-product-id="penger-v1">
            <span class="order-gallery-badge"><%= t.order.productName %></span>
            <div class="order-gallery-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
              </svg>
              <span><%= t.order.galleryPlaceholder %></span>
            </div>
          </div>

          <!-- Plates quantity (1-4, extra +35€) -->
          <div class="order-section" data-section="order">
            <p class="order-section-title"><%= t.order.platesLabel %></p>
            <div class="order-section-row" style="align-items:center">
              <div class="qty-selector" data-track="config_plates" data-cta-id="order_plates_qty" data-section="order" data-product-id="penger-v1">
                <button class="qty-btn" id="platesMinus" type="button" disabled aria-label="Decrease plates">&minus;</button>
                <span class="qty-val" id="platesVal">1</span>
                <button class="qty-btn" id="platesPlus" type="button" aria-label="Increase plates">&plus;</button>
              </div>
              <span class="order-section-price"><%= t.order.platesExtraPrice %></span>
            </div>
          </div>

          <!-- Security sleeve colour -->
          <div class="config-card" data-section="order">
            <div class="config-card-header">
              <span class="config-card-title">Security sleeve</span>
              <span class="config-card-price">+&euro;10</span>
            </div>
            <div class="config-options" id="sleeveOptions">
              <label class="config-opt active">
                <input type="radio" name="sleeveColor" value="black" checked>
                <span class="config-swatch config-swatch-black"></span>
                Black
              </label>
              <label class="config-opt">
                <input type="radio" name="sleeveColor" value="white">
                <span class="config-swatch config-swatch-white"></span>
                White
              </label>
            </div>
          </div>

          <!-- Precision center punch tool -->
          <div class="config-card" data-section="order">
            <div class="config-card-header">
              <span class="config-card-title">Precision center punch tool</span>
              <span class="config-card-price">+&euro;10</span>
            </div>
            <div class="config-options" id="punchOptions">
              <label class="config-opt active">
                <input type="radio" name="punchTool" value="yes" checked>
                Yes
              </label>
              <label class="config-opt">
                <input type="radio" name="punchTool" value="no">
                No
              </label>
            </div>
          </div>

          <!-- Kit contents -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.kitContentsLabel %></p>
            <div class="kit-description">
              <p><%= t.order.kitDesc %></p>
            </div>
            <ul class="kit-list">
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem1 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem2 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem3 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem4 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem5 %></li>
              <li><svg class="kit-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg> <%= t.order.kitItem6 %></li>
            </ul>
          </div>

          <!-- Specs -->
          <div class="order-section">
            <p class="order-section-title"><%= t.order.specsLabel %></p>
            <table class="specs-table">
              <tr><td><%= t.order.specMaterial %></td><td><%= t.order.specMaterialVal %></td></tr>
              <tr><td><%= t.order.specDimensions %></td><td><%= t.order.specDimensionsVal %></td></tr>
              <tr><td><%= t.order.specCapacity %></td><td><%= t.order.specCapacityVal %></td></tr>
              <tr><td><%= t.order.specWeight %></td><td><%= t.order.specWeightVal %></td></tr>
              <tr><td><%= t.order.specFire %></td><td><%= t.order.specFireVal %></td></tr>
            </table>
          </div>

          <!-- ===== STEP 1: CONTACT INFO ===== -->
          <div class="checkout-step active" id="stepContact" data-section="order">
            <div class="step-header">
              <div class="step-header-left">
                <span class="step-number">1</span>
                <span class="step-title"><%= t.order.progressContact %></span>
              </div>
              <button class="step-edit-btn" id="editContact" type="button"><%= t.order.stepEdit %></button>
            </div>
            <div class="step-summary" id="contactSummary"></div>
            <div class="step-body">
              <div class="form-privacy">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span><%= t.order.privacyNote %> <a href="<%= langPrefix %>/cookie-policy" style="color:var(--text-accent);text-decoration:underline"><%= t.order.privacyLearnMore %></a></span>
              </div>
              <form id="contactForm" autocomplete="on" novalidate>
                <div class="form-row">
                  <div class="form-group">
                    <div class="form-input-wrap">
                      <input class="form-input form-input-lg" type="text" id="firstName" name="given-name" autocomplete="given-name" placeholder="<%= t.order.firstName %>" aria-describedby="firstNameError" required>
                      <svg class="input-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="field-error-msg" id="firstNameError" role="alert"></div>
                  </div>
                  <div class="form-group">
                    <div class="form-input-wrap">
                      <input class="form-input form-input-lg" type="text" id="lastName" name="family-name" autocomplete="family-name" placeholder="<%= t.order.lastName %>" aria-describedby="lastNameError" required>
                      <svg class="input-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="field-error-msg" id="lastNameError" role="alert"></div>
                  </div>
                </div>
                <div class="form-row full">
                  <div class="form-group">
                    <div class="form-input-wrap">
                      <input class="form-input form-input-lg" type="email" id="email" name="email" autocomplete="email" inputmode="email" placeholder="<%= t.order.email %>" aria-describedby="emailError" required>
                      <svg class="input-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    </div>
                    <div class="email-suggestion" id="emailSuggestion"></div>
                    <div class="field-error-msg" id="emailError" role="alert"></div>
                  </div>
                </div>
                <div class="form-row full">
                  <div class="form-group">
                    <label class="form-label" for="country"><%= t.order.countryOfDelivery || 'Country of delivery' %></label>
                    <select class="form-input" id="country" name="country" autocomplete="country-name" required>
                      <option value="" disabled selected><%= t.order.countryPlaceholder %></option>
                      <option value="AT">&#127462;&#127481; Austria</option>
                      <option value="BE">&#127463;&#127466; Belgium</option>
                      <option value="BG">&#127463;&#127468; Bulgaria</option>
                      <option value="HR">&#127469;&#127479; Croatia</option>
                      <option value="CY">&#127464;&#127486; Cyprus</option>
                      <option value="CZ">&#127464;&#127487; Czech Republic</option>
                      <option value="DK">&#127465;&#127472; Denmark</option>
                      <option value="EE">&#127466;&#127466; Estonia</option>
                      <option value="FI">&#127467;&#127470; Finland</option>
                      <option value="FR">&#127467;&#127479; France</option>
                      <option value="DE">&#127465;&#127466; Germany</option>
                      <option value="GR">&#127468;&#127479; Greece</option>
                      <option value="HU">&#127469;&#127482; Hungary</option>
                      <option value="IE">&#127470;&#127466; Ireland</option>
                      <option value="IT">&#127470;&#127481; Italy</option>
                      <option value="LV">&#127473;&#127483; Latvia</option>
                      <option value="LT">&#127473;&#127481; Lithuania</option>
                      <option value="LU">&#127473;&#127482; Luxembourg</option>
                      <option value="MT">&#127474;&#127481; Malta</option>
                      <option value="NL">&#127475;&#127473; Netherlands</option>
                      <option value="PL">&#127477;&#127473; Poland</option>
                      <option value="PT">&#127477;&#127481; Portugal</option>
                      <option value="RO">&#127479;&#127476; Romania</option>
                      <option value="SK">&#127480;&#127472; Slovakia</option>
                      <option value="SI">&#127480;&#127470; Slovenia</option>
                      <option value="ES">&#127466;&#127480; Spain</option>
                      <option value="SE">&#127480;&#127466; Sweden</option>
                      <option value="GB">&#127468;&#127463; United Kingdom</option>
                      <option value="US">&#127482;&#127480; United States</option>
                      <option value="CA">&#127464;&#127462; Canada</option>
                      <option value="AU">&#127462;&#127482; Australia</option>
                      <option value="JP">&#127471;&#127477; Japan</option>
                      <option value="CH">&#127464;&#127469; Switzerland</option>
                      <option value="NO">&#127475;&#127476; Norway</option>
                      <option value="UA">&#127482;&#127462; Ukraine</option>
                    </select>
                  </div>
                </div>
                <div class="form-row full">
                  <div class="form-group">
                    <div class="phone-wrap">
                      <span class="phone-prefix" id="phonePrefix">+</span>
                      <input class="form-input" type="tel" id="phone" name="phone" autocomplete="tel-national" inputmode="tel" placeholder="<%= t.order.phone %>" aria-describedby="phoneError" required>
                    </div>
                    <div class="field-error-msg" id="phoneError" role="alert"></div>
                  </div>
                </div>
                <button class="step-continue-btn" id="contactContinue" type="submit"><%= t.order.deliveryAddress || 'Continue to Delivery' %></button>
              </form>
            </div>
          </div>

          <!-- ===== STEP 2: DELIVERY ADDRESS ===== -->
          <div class="checkout-step disabled" id="stepDelivery" data-section="order">
            <div class="step-header">
              <div class="step-header-left">
                <span class="step-number">2</span>
                <span class="step-title"><%= t.order.deliveryAddress %></span>
              </div>
              <button class="step-edit-btn" id="editDelivery" type="button"><%= t.order.stepEdit %></button>
            </div>
            <div class="step-summary" id="deliverySummary"></div>
            <div class="step-body">
              <form id="deliveryForm" autocomplete="on" novalidate>
                <div class="form-row full">
                  <div class="form-group">
                    <input class="form-input form-input-lg" type="text" id="street" name="address-line1" autocomplete="address-line1" placeholder="<%= t.order.street %>" aria-describedby="streetError" required>
                    <div class="field-error-msg" id="streetError" role="alert"></div>
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <input class="form-input form-input-sm" type="text" id="apt" name="address-line2" autocomplete="address-line2" placeholder="<%= t.order.apt %>">
                  </div>
                  <div class="form-group">
                    <input class="form-input form-input-sm" type="text" id="zip" name="postal-code" autocomplete="postal-code" inputmode="text" placeholder="<%= t.order.zip %>" aria-describedby="zipError" required>
                    <div class="field-error-msg" id="zipError" role="alert"></div>
                    <div class="zip-suggestions" id="zipSuggestions"></div>
                  </div>
                </div>
                <div class="form-row full">
                  <div class="form-group">
                    <input class="form-input" type="text" id="city" name="city" autocomplete="address-level2" placeholder="<%= t.order.city %>" aria-describedby="cityError" required>
                    <div class="field-error-msg" id="cityError" role="alert"></div>
                  </div>
                </div>
                <div class="delivery-estimate" id="deliveryEstimate" style="display:none">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span id="deliveryText"></span>
                </div>
                <button class="step-continue-btn" id="deliveryContinue" type="submit"><%= t.order.continueToPayment %></button>
              </form>
            </div>
          </div>

          <!-- ===== STEP 3: PAYMENT ===== -->
          <div class="checkout-step disabled" id="stepPayment" data-section="order">
            <div class="step-header">
              <div class="step-header-left">
                <span class="step-number">3</span>
                <span class="step-title"><%= t.order.stepPaymentTitle %></span>
              </div>
            </div>
            <div class="step-body">
              <div class="pay-methods" id="payMethods" role="radiogroup" aria-label="<%= t.order.stepPaymentTitle %>">
                <label class="pay-method active" data-method="card">
                  <input type="radio" name="payMethod" value="card" checked>
                  <span class="pay-radio"><span class="pay-radio-dot"></span></span>
                  <span class="pay-method-info">
                    <span class="pay-method-name"><%= t.order.payCard %></span>
                  </span>
                  <span class="pay-method-icons" id="cardTypeIcons">
                    <span data-card="visa">VISA</span>
                    <span data-card="mc">MC</span>
                    <span data-card="amex">AMEX</span>
                  </span>
                </label>
                <label class="pay-method" data-method="apple">
                  <input type="radio" name="payMethod" value="apple">
                  <span class="pay-radio"><span class="pay-radio-dot"></span></span>
                  <span class="pay-method-info">
                    <span class="pay-method-name">Apple Pay</span>
                  </span>
                </label>
                <label class="pay-method" data-method="google">
                  <input type="radio" name="payMethod" value="google">
                  <span class="pay-radio"><span class="pay-radio-dot"></span></span>
                  <span class="pay-method-info">
                    <span class="pay-method-name">Google Pay</span>
                  </span>
                </label>
                <label class="pay-method" data-method="crypto">
                  <input type="radio" name="payMethod" value="crypto">
                  <span class="pay-radio"><span class="pay-radio-dot"></span></span>
                  <span class="pay-method-info">
                    <span class="pay-method-name"><%= t.order.payCrypto %></span>
                    <span class="pay-method-desc"><%= t.order.payCryptoDesc %></span>
                  </span>
                </label>
              </div>

              <!-- Card fields -->
              <div class="card-fields" id="cardFields">
                <div class="form-row full">
                  <div class="form-group">
                    <label class="form-label" for="cardNumber"><%= t.order.cardNumber %></label>
                    <input class="form-input" type="text" id="cardNumber" inputmode="numeric" placeholder="1234 5678 9012 3456" autocomplete="cc-number">
                  </div>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label class="form-label" for="cardExpiry"><%= t.order.cardExpiry %></label>
                    <input class="form-input" type="text" id="cardExpiry" inputmode="numeric" placeholder="MM/YY" autocomplete="cc-exp">
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="cardCvc"><%= t.order.cardCvc %></label>
                    <input class="form-input" type="text" id="cardCvc" inputmode="numeric" placeholder="123" autocomplete="cc-csc">
                  </div>
                </div>
                <div class="form-row full">
                  <div class="form-group">
                    <label class="form-label" for="cardName"><%= t.order.cardName %></label>
                    <input class="form-input" type="text" id="cardName" autocomplete="cc-name">
                  </div>
                </div>
              </div>

              <!-- Checkboxes -->
              <div style="margin-top:16px">
                <label class="form-checkbox">
                  <input type="checkbox" id="agreeTerms" required>
                  <span class="checkbox-box">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </span>
                  <span class="checkbox-label"><%- t.order.agreeTerms %></span>
                </label>
                <label class="form-checkbox">
                  <input type="checkbox" id="newsletter">
                  <span class="checkbox-box">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                  </span>
                  <span class="checkbox-label"><%= t.order.newsletter %></span>
                </label>
              </div>

              <!-- Bottom order summary card -->
              <div class="order-bottom-card">
                <div class="cart-item" style="border-bottom:none;margin-bottom:0;padding-bottom:0">
                  <div class="cart-thumb">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                    </svg>
                  </div>
                  <div class="cart-details">
                    <div class="cart-product-name"><%= t.order.productName %></div>
                    <div class="cart-config-line"><%= t.order.cartPlates %>: <span id="cartPlatesBottom">1</span></div>
                  </div>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-row">
                  <span class="summary-key"><%= t.order.priceLabel %></span>
                  <span class="summary-val"><%= t.order.priceValue %></span>
                </div>
                <div class="summary-row" id="rowExtraPlatesBottom" style="display:none">
                  <span class="summary-key" id="extraPlatesLabelBottom"></span>
                  <span class="summary-val-add" id="extraPlatesPriceBottom"></span>
                </div>
                <div class="summary-row" id="rowSleeveBottom">
                  <span class="summary-key" id="sleeveLabelBottom">Sleeve</span>
                  <span class="summary-val-add" id="sleevePriceBottom">+&euro;10</span>
                </div>
                <div class="summary-row" id="rowPunchBottom">
                  <span class="summary-key" id="punchLabelBottom">Punch tool</span>
                  <span class="summary-val-add" id="punchPriceBottom">+&euro;10</span>
                </div>
                <div class="summary-row" id="rowShippingFreeBottom">
                  <span class="summary-key"><%= t.order.shippingLabel %></span>
                  <span class="summary-val-free"><%= t.order.shippingValue %></span>
                </div>
                <div class="summary-row" id="rowShippingCostBottom" style="display:none">
                  <span class="summary-key"><%= t.order.shippingLabel %></span>
                  <span class="summary-val-add" id="shippingCostValBottom"></span>
                </div>
                <div class="summary-row" id="rowDiscountBottom" style="display:none">
                  <span class="summary-key"><%= t.order.promoDiscount %></span>
                  <span class="summary-val" id="discountValBottom" style="color:#2ecc71"></span>
                </div>
                <div class="summary-divider"></div>
                <div class="summary-row summary-total">
                  <span class="summary-key"><%= t.order.totalLabel %></span>
                  <span class="summary-val" id="summaryTotalBottom" aria-live="polite">€69</span>
                </div>
              </div>

              <button class="order-checkout-btn" id="checkoutBtn" type="button" style="margin-top:16px" disabled
                data-track="checkout_start" data-cta-id="order_checkout" data-section="order" data-product-id="penger-v1">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                <span id="checkoutBtnText"><%= t.order.payNow %></span>
              </button>
              <div class="trust-badges">
                <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  <%= t.order.trustSecure %>
                </span>
                <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  <%= t.order.trustSSL %>
                </span>
                <span class="trust-badge">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
                  <%= t.order.trustGuarantee %>
                </span>
              </div>
            </div>
          </div>

        </div>

        <!-- ===== RIGHT: ORDER SUMMARY ===== -->
        <div class="order-sidebar">
          <div class="order-summary" data-section="order">
            <p class="order-summary-title"><%= t.order.summaryLabel %></p>

            <!-- Cart item card -->
            <div class="cart-item">
              <div class="cart-thumb">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                </svg>
              </div>
              <div class="cart-details">
                <div class="cart-product-name"><%= t.order.productName %></div>
                <div class="cart-config-line"><%= t.order.cartPlates %>: <span id="cartPlates">1</span></div>
                <div class="cart-config-line"><%= t.order.cartKit %>: <span><%= t.order.cartIncluded %></span></div>
              </div>
            </div>

            <!-- Price breakdown -->
            <div class="summary-row">
              <span class="summary-key"><%= t.order.priceLabel %></span>
              <span class="summary-val"><%= t.order.priceValue %></span>
            </div>
            <div class="summary-row" id="rowExtraPlates" style="display:none">
              <span class="summary-key" id="extraPlatesLabel"></span>
              <span class="summary-val-add" id="extraPlatesPrice"></span>
            </div>
            <div class="summary-row" id="rowSleeve">
              <span class="summary-key" id="sleeveLabel">Sleeve</span>
              <span class="summary-val-add" id="sleevePrice">+&euro;10</span>
            </div>
            <div class="summary-row" id="rowPunch">
              <span class="summary-key" id="punchLabel">Punch tool</span>
              <span class="summary-val-add" id="punchPrice">+&euro;10</span>
            </div>
            <div class="summary-row" id="rowShippingFree">
              <span class="summary-key"><%= t.order.shippingLabel %></span>
              <span class="summary-val-free" id="shippingFreeVal"><%= t.order.shippingValue %></span>
            </div>

            <div class="summary-row" id="rowShippingCost" style="display:none">
              <span class="summary-key"><%= t.order.shippingLabel %></span>
              <span class="summary-val-add" id="shippingCostVal"></span>
            </div>
            <div class="summary-row" id="rowDiscount" style="display:none">
              <span class="summary-key" id="discountLabel"><%= t.order.promoDiscount %></span>
              <span class="summary-val" id="discountVal" style="color:#2ecc71"></span>
            </div>

            <div class="summary-divider"></div>

            <div class="summary-row summary-total">
              <span class="summary-key"><%= t.order.totalLabel %></span>
              <span class="summary-val" id="summaryTotal" aria-live="polite">€69</span>
            </div>

            <div class="promo-section">
              <div class="promo-form open" id="promoForm">
                <input class="promo-input" type="text" id="promoInput" placeholder="<%= t.order.promoPlaceholder %>" maxlength="20">
                <button class="promo-apply" id="promoApply" type="button"><%= t.order.promoApply %></button>
              </div>
              <div class="promo-msg" id="promoMsg"></div>
            </div>

            <div class="order-notes">
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <%= t.order.preorderNote %>
              </span>
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <%= t.order.warrantyNote %>
              </span>
              <span class="order-note">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <%= t.order.secureNote %>
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>

  <!-- Sticky mobile CTA -->
  <div class="mobile-sticky-cta" id="mobileCta">
    <span class="mobile-sticky-price" id="mobilePrice">€69</span>
    <button class="mobile-sticky-btn" id="mobileContinueBtn" type="button"><%= t.order.continueToPayment %></button>
  </div>

  <%- include('../partials/footer') %>

  <script>
  window.ORDER_I18N = {
    platesDesc: '<%= t.order.platesDesc %>',
    langPrefix: '<%= langPrefix %>',
    stepEdit: '<%= t.order.stepEdit %>',
    firstName: '<%= t.order.firstName %>',
    lastName: '<%= t.order.lastName %>',
    email: '<%= t.order.email %>',
    phone: '<%= t.order.phone %>',
    country: '<%= t.order.country %>',
    continueToDelivery: '<%= t.order.deliveryAddress || "Continue to Delivery" %>',
    continueToPayment: '<%= t.order.continueToPayment %>',
    payNow: '<%= t.order.payNow %>',
    emailDidYouMean: '<%= t.order.emailDidYouMean %>',
    errorRequired: '<%= t.order.errorRequired %>',
    errorEmail: '<%= t.order.errorEmail %>',
    errorPhone: '<%= t.order.errorPhone %>',
    deliveryEU: '<%- t.order.deliveryEU %>',
    deliveryUS: '<%- t.order.deliveryUS %>',
    deliveryOther: '<%- t.order.deliveryOther %>',
    shippingFreeLabel: '<%= t.order.shippingValue %>',
    processing: '<%= t.order.processing %>',
    promoInvalid: '<%= t.order.promoInvalid %>',
    promoApplied: '<%= t.order.promoApplied %>'
  };
  </script>
  <script src="/analytics.js"></script>
  <script src="/shared.js?v=2"></script>
  <% if (typeof extraJs !== 'undefined') { extraJs.forEach(function(js) { %>
  <script src="/<%= js %>"></script>
  <% }); } %>
</body>
</html>
