<!DOCTYPE html><html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
  <% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(css) { %>
  <link rel="stylesheet" href="/<%= css %>">
  <% }); } %>

  <!-- Chat-layout overrides: flex shell + keyboard -->
  <style>
    :root { --kb: 0px; }

    html, body { height: 100%; }
    html { height: 100dvh; }
    body {
      display: flex;
      flex-direction: column;
      height: 100dvh;
      margin: 0;
      overflow: hidden;
    }

    /* Nav overlay: invisible & non-interactive by default */
    .nav-overlay {
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
    }
    .nav-overlay.is-open {
      pointer-events: auto;
      opacity: 1;
      visibility: visible;
    }

    .site-header { flex-shrink: 0; }

    main {
      flex: 1 1 0%;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 0;
    }
    main > .section-intro { flex-shrink: 0; }
    main > .section-block {
      flex: 1 1 0%;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 0;
    }
    main > .section-block > .container {
      flex: 1 1 0%;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      min-height: 0;
    }

    /* === Scrollable messages container === */
    #tutorChat {
      flex: 1 1 0%;
      min-height: 0;                        /* critical for flex child scroll */
      overflow-y: auto;
      overflow-x: hidden;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: contain;
      touch-action: pan-y;
      /* room for the fixed composer + safe-area + keyboard */
      padding-bottom: calc(80px + env(safe-area-inset-bottom, 0px) + var(--kb));
    }

    /* Fixed composer driven by --kb */
    .tutor-input-bar {
      position: fixed !important;
      left: 0; right: 0;
      bottom: calc(env(safe-area-inset-bottom, 0px) + var(--kb)) !important;
      z-index: 100;
    }

    /* 16 px prevents iOS auto-zoom on focus */
    .tutor-input { font-size: 16px !important; }

    /* === Intro collapse/expand === */
    .section-intro {
      overflow: hidden;
      padding-bottom: 24px; /* room for the chevron button */
      transition: max-height var(--duration-normal) var(--ease-default),
                  padding var(--duration-normal) var(--ease-default),
                  opacity 0.3s var(--ease-default),
                  border-color 0.3s var(--ease-default);
      will-change: max-height, padding, opacity;
    }
    .section-intro.is-collapsing {
      opacity: 0;
      pointer-events: none;
    }
    .section-intro.is-collapsed {
      max-height: 0 !important;
      padding-top: 0 !important;
      padding-bottom: 0 !important;
      border-bottom-color: transparent !important;
      opacity: 0;
      pointer-events: none;
    }

    /* Chevron toggle at bottom center of intro */
    .intro-toggle-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      margin: 10px auto 0;
      background: none;
      border: 1px solid var(--border-default);
      border-radius: 50%;
      cursor: pointer;
      color: var(--text-dim);
      transition: color 0.2s var(--ease-default),
                  border-color 0.2s var(--ease-default),
                  background 0.2s var(--ease-default);
    }
    .intro-toggle-btn:hover {
      color: var(--text-accent);
      border-color: var(--border-active);
      background: var(--bg-surface-hover);
    }
    .intro-toggle-btn .intro-toggle-icon {
      transition: transform 0.35s var(--ease-default);
      flex-shrink: 0;
    }

    /* Expand bar — visible when collapsed */
    #introExpandBar {
      flex-shrink: 0;
      display: flex;
      justify-content: center;
      padding: 0;
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: max-height 0.35s var(--ease-default),
                  opacity 0.3s var(--ease-default),
                  padding 0.35s var(--ease-default);
    }
    #introExpandBar.is-visible {
      max-height: 48px;
      opacity: 1;
      padding: 6px 0;
    }
    #introExpandBar button {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      background: none;
      border: 1px solid var(--border-default);
      border-radius: 50%;
      cursor: pointer;
      color: var(--text-dim);
      transition: color 0.2s var(--ease-default),
                  border-color 0.2s var(--ease-default),
                  background 0.2s var(--ease-default);
    }
    #introExpandBar button:hover {
      color: var(--text-accent);
      border-color: var(--border-active);
      background: var(--bg-surface-hover);
    }
  </style>

  <title><%= pageTitle %></title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "<%= pageTitle %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/ai-tutor",
    "description": "<%= pageDescription %>",
    "applicationCategory": "EducationalApplication",
    "operatingSystem": "All",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "<%= lang === 'uk' ? 'Головна' : 'Home' %>", "item": "<%= canonicalBase %><%= langPrefix %>/" },
      { "@type": "ListItem", "position": 2, "name": "<%= lang === 'uk' ? 'AI Тьютор' : 'AI Tutor' %>" }
    ]
  }
  </script>
</head>
<body>
  <%- include('../partials/gtm-body') %>
  <noscript><p style="padding:40px;text-align:center;font-size:16px;">JavaScript is required.</p></noscript>
  <%- include('../partials/header') %>

  <main>
    <!-- SECTION INTRO -->
    <section class="section-intro" id="tutorIntro" data-section="tutor-intro">
      <div class="container">
        <p class="label"><%= t.aiTutor.label %></p>
        <h1><%= t.aiTutor.h1 %></h1>
        <p class="body-text">
          <%= t.aiTutor.intro %>
        </p>
      </div>
      <button class="intro-toggle-btn" id="introCollapseBtn" type="button" aria-expanded="true" aria-controls="tutorIntro">
        <svg class="intro-toggle-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 6L8 11L13 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </section>

    <!-- Expand chevron (visible when intro is collapsed) -->
    <div id="introExpandBar">
      <button type="button" id="introExpandBtn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 10L8 5L13 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <!-- CHAT SECTION -->
    <section class="section-block" style="border-bottom:none;" data-section="tutor-chat">
      <div class="container">
        <div class="tutor-chat" id="tutorChat">
          <!-- Messages are rendered here by JS -->
        </div>
      </div>
    </section>
  </main>

  <!-- INPUT BAR (fixed at bottom) -->
  <div class="tutor-input-bar" id="tutorInputBar">
    <div class="container">
      <div class="tutor-input-wrap">
        <input class="tutor-input" id="tutorInput" type="text" placeholder="<%= t.aiTutor.placeholder %>" maxlength="2000" autocomplete="off" enterkeyhint="send" inputmode="text">
        <button class="tutor-send-btn" id="tutorSendBtn" type="button" disabled aria-label="Send" data-track="cta_click" data-cta-id="tutor_send_message" data-section="tutor-chat">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>

  <script>
  window.TUTOR_I18N = {
    langPrefix: '<%= langPrefix %>',
    lang: '<%= lang %>',
    retry: '<%= lang === "uk" ? "Спробувати знову" : "Retry" %>',
    rateLimited: '<%= t.aiTutor.rateLimited %>',
    serviceUnavailable: '<%= t.aiTutor.serviceUnavailable %>',
    errorMsg: '<%= t.aiTutor.errorMsg %>',
    emptyResponse: '<%= t.aiTutor.emptyResponse %>',
    connectionError: '<%= t.aiTutor.connectionError %>'
  };
  </script>
  <script src="/analytics.js"></script>
  <script src="/shared.js?v=3"></script>
  <% if (typeof extraJs !== 'undefined') { extraJs.forEach(function(js) { %>
  <script src="/<%= js %>"></script>
  <% }); } %>
</body>
</html>
