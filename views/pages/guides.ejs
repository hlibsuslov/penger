<!DOCTYPE html><html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
  <% if (typeof extraCss !== 'undefined') { extraCss.forEach(function(css) { %>
  <link rel="stylesheet" href="/<%= css %>">
  <% }); } %>
  <title><%= pageTitle %></title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "<%= pageTitle %>",
    "url": "<%= canonicalBase %><%= langPrefix %>/guides",
    "description": "<%= pageDescription %>",
    "publisher": {
      "@type": "Organization",
      "name": "PENGER",
      "logo": {
        "@type": "ImageObject",
        "url": "<%= canonicalBase %>/PENGER.svg"
      }
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "<%= lang === 'uk' ? 'Головна' : 'Home' %>", "item": "<%= canonicalBase %><%= langPrefix %>/" },
      { "@type": "ListItem", "position": 2, "name": "<%= lang === 'uk' ? 'Академія' : 'Academy' %>" }
    ]
  }
  </script>
</head>
<body>
  <%- include('../partials/gtm-body') %>
  <noscript><p style="padding:40px;text-align:center;font-size:16px;">JavaScript is required.</p></noscript>
  <%- include('../partials/header') %>

  <main>

    <!-- ACADEMY HERO -->
    <section class="academy-hero">
      <div class="container">
        <p class="label"><%= t.index.academyLabel %></p>
        <h1  style="margin-top:8px; margin-bottom:12px;"><%= t.index.academyH2 %></h1>
        <p class="body-text">
          <%= t.index.academyDesc %>
        </p>
        <div style="margin-top:20px; display:flex; gap:20px; flex-wrap:wrap;" >
          <div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
            <span style="color:var(--text-accent); font-weight:700;">7</span>&nbsp;<%= t.index.academyStat1.replace('7 ', '') %>
          </div>
          <div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
            <span style="color:var(--text-accent); font-weight:700;">2</span>&nbsp;<%= t.index.academyStat2.replace('2 ', '') %>
          </div>
          <div style="font-family:var(--font-mono); font-size:12px; color:var(--text-dim);">
            <%= t.index.academyStat3 %>
          </div>
        </div>
      </div>
    </section>

    <!-- FOUNDATIONS SECTION -->
    <section class="academy-section">
      <div class="container">
        <div class="academy-section-title"><%= t.index.foundationsLabel %></div>
        <div class="card-grid">

          <a class="card" href="<%= langPrefix %>/guides/seed-anatomy">
            <div class="card-title"><%= t.index.guideSeedTitle %></div>
            <p class="card-desc">
              <%= t.index.guideSeedDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

          <a class="card" href="<%= langPrefix %>/guides/wallet-anatomy">
            <div class="card-title"><%= t.index.guideWalletTitle %></div>
            <p class="card-desc">
              <%= t.index.guideWalletDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

          <a class="card" href="<%= langPrefix %>/guides/self-sovereignty">
            <div class="card-title"><%= t.index.guideSovereigntyTitle %></div>
            <p class="card-desc">
              <%= t.index.guideSovereigntyDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

        </div>
      </div>
    </section>

    <!-- SECURITY SECTION -->
    <section class="academy-section">
      <div class="container">
        <div class="academy-section-title"><%= t.index.securityLabel %></div>
        <div class="card-grid">

          <a class="card" href="<%= langPrefix %>/guides/wallet-comparison">
            <div class="card-title"><%= t.index.guideComparisonTitle %></div>
            <p class="card-desc">
              <%= t.index.guideComparisonDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

          <a class="card" href="<%= langPrefix %>/guides/opsec">
            <div class="card-title"><%= t.index.guideOpsecTitle %></div>
            <p class="card-desc">
              <%= t.index.guideOpsecDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

          <a class="card" href="<%= langPrefix %>/guides/passphrase">
            <div class="card-title"><%= t.index.guidePassphraseTitle %></div>
            <p class="card-desc">
              <%= t.index.guidePassphraseDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

          <a class="card" href="<%= langPrefix %>/guides/multisig">
            <div class="card-title"><%= t.index.guideMultisigTitle %></div>
            <p class="card-desc">
              <%= t.index.guideMultisigDesc %>
            </p>
            <span class="card-link"><%= t.index.readGuide %></span>
          </a>

        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script src="/analytics.js"></script>
  <script src="/shared.js?v=3"></script>
</body>
</html>
